# KQL MCP Server Configuration
# Copy this file to .env and fill in your values

# ─── Azure Data Explorer (ADX) Connections ───────────────────────────────────
# Multiple clusters can be configured as JSON array in ADX_CLUSTERS
# Each entry: {"name": "alias", "cluster_url": "https://...", "database": "default_db"}
ADX_CLUSTERS='[{"name": "my-cluster", "cluster_url": "https://mycluster.eastus.kusto.windows.net", "database": "mydb"}]'

# ─── Log Analytics / Sentinel Workspaces ─────────────────────────────────────
# Multiple workspaces as JSON array
# Each entry: {"name": "alias", "workspace_id": "...", "subscription_id": "..."}
LOG_ANALYTICS_WORKSPACES='[{"name": "sentinel", "workspace_id": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"}]'

# ─── Authentication ───────────────────────────────────────────────────────────
# Options: "cli" (az login), "managed_identity", "service_principal", "interactive"
AZURE_AUTH_METHOD=cli

# For service_principal auth only:
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ─── Query Settings ───────────────────────────────────────────────────────────
# Maximum rows returned by queries (default: 10000)
MAX_QUERY_ROWS=10000

# Query timeout in seconds (default: 120)
QUERY_TIMEOUT_SECONDS=120

# Maximum query duration for cost warning (in seconds)
COST_WARNING_THRESHOLD_SECONDS=30

# ─── Cache Settings ───────────────────────────────────────────────────────────
# How long to cache schema information (in minutes)
SCHEMA_CACHE_TTL_MINUTES=30

# ─── Output Format ───────────────────────────────────────────────────────────
# Default result format: "table", "json", "csv", "markdown"
DEFAULT_OUTPUT_FORMAT=markdown
